{
  "name": "@sito/dashboard",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": "^22.13.0"
  },
  "description": "UI library with custom components for dashboards",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "homepage": "https://github.com/sito8943/-sito-dashboard#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/sito8943/-sito-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/sito8943/-sito-dashboard/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./Badge": {
      "types": "./dist/components/Badge/index.d.ts",
      "import": "./dist/Badge.js",
      "require": "./dist/Badge.cjs"
    },
    "./Button": {
      "types": "./dist/components/Button/index.d.ts",
      "import": "./dist/Button.js",
      "require": "./dist/Button.cjs"
    },
    "./Chip": {
      "types": "./dist/components/Chip/index.d.ts",
      "import": "./dist/Chip.js",
      "require": "./dist/Chip.cjs"
    },
    "./Dropdown": {
      "types": "./dist/components/Dropdown/index.d.ts",
      "import": "./dist/Dropdown.js",
      "require": "./dist/Dropdown.cjs"
    },
    "./Form": {
      "types": "./dist/components/Form/index.d.ts",
      "import": "./dist/Form.js",
      "require": "./dist/Form.cjs"
    },
    "./IconButton": {
      "types": "./dist/components/IconButton/index.d.ts",
      "import": "./dist/IconButton.js",
      "require": "./dist/IconButton.cjs"
    },
    "./Loading": {
      "types": "./dist/components/Loading/index.d.ts",
      "import": "./dist/Loading.js",
      "require": "./dist/Loading.cjs"
    },
    "./SvgIcons": {
      "types": "./dist/components/SvgIcons/index.d.ts",
      "import": "./dist/SvgIcons.js",
      "require": "./dist/SvgIcons.cjs"
    },
    "./Table": {
      "types": "./dist/components/Table/index.d.ts",
      "import": "./dist/Table.js",
      "require": "./dist/Table.cjs"
    },
    "./Tooltip": {
      "types": "./dist/components/Tooltip/index.d.ts",
      "import": "./dist/Tooltip.js",
      "require": "./dist/Tooltip.cjs"
    },
    "./FiltersProvider": {
      "types": "./dist/providers/FiltersProvider/index.d.ts",
      "import": "./dist/FiltersProvider.js",
      "require": "./dist/FiltersProvider.cjs"
    },
    "./TableOptions": {
      "types": "./dist/providers/TableOptions/index.d.ts",
      "import": "./dist/TableOptions.js",
      "require": "./dist/TableOptions.cjs"
    },
    "./Translation": {
      "types": "./dist/providers/Translation/index.d.ts",
      "import": "./dist/Translation.js",
      "require": "./dist/Translation.cjs"
    },
    "./lib": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib.js",
      "require": "./dist/lib.cjs"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "oxlint --type-aware --max-warnings 0",
    "lint:fix": "oxlint --type-aware --fix --max-warnings 0",
    "deps:check": "knip --dependencies",
    "test": "vitest run",
    "preview": "vite preview",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky",
    "full": "pnpm run lint && pnpm run format:check && pnpm run deps:check && pnpm run build && pnpm run test"
  },
  "keywords": [
    "sito",
    "dashboard"
  ],
  "author": "sito8943",
  "license": "MIT",
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@sito/ui": "0.3.1"
  },
  "overrides": {
    "lodash": "4.18.1",
    "esbuild": "0.28.1"
  },
  "pnpm": {
    "overrides": {
      "lodash": "4.18.1",
      "esbuild": "0.28.1"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --type-aware --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{js,jsx,css,json,md}": "prettier --write"
  },
  "devDependencies": {
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/react": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/typescript6": "^6.0.2",
    "@vitejs/plugin-react": "6.0.3",
    "baseline-browser-mapping": "^2.10.0",
    "husky": "^9.1.7",
    "jsdom": "29.1.1",
    "knip": "6.25.0",
    "lint-staged": "^16.2.7",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "postcss": "^8.5.0",
    "prettier": "3.9.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.71.2",
    "storybook": "10.4.6",
    "tailwindcss": "^4.0.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vite-plugin-dts": "5.0.3",
    "vite-plugin-lib-inject-css": "1.3.0",
    "vitest": "4.1.10"
  }
}
