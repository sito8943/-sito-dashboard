{
  "name": "@sito/dashboard",
  "private": false,
  "version": "0.0.64",
  "type": "module",
  "description": "UI library with custom components for dashboards",
  "main": "dist/dashboard.cjs",
  "module": "dist/dashboard.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "homepage": "https://github.com/sito8943/-sito-dashboard#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/sito8943/-sito-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/sito8943/-sito-dashboard/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/dashboard.js",
      "require": "./dist/dashboard.cjs"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint --fix . --report-unused-disable-directives --max-warnings 0 && prettier --write . && depcheck .",
    "test": "vitest run",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky",
    "full": "npm run lint; npm run build; npm run test"
  },
  "keywords": [
    "sito",
    "dashboard"
  ],
  "author": "sito8943",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.2 <20"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --report-unused-disable-directives --max-warnings 0",
      "prettier --write"
    ],
    "*.{js,jsx,css,json,md}": "prettier --write"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.13",
    "@storybook/react": "^10.2.10",
    "@storybook/react-vite": "^10.2.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.19.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "10.4.16",
    "baseline-browser-mapping": "^2.10.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.6.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.2.7",
    "postcss": "8.4.41",
    "prettier": "^3.8.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "storybook": "^10.2.10",
    "tailwindcss": "3.4.10",
    "typescript": "5.5.4",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lib-inject-css": "1.3.0",
    "vitest": "^3.2.1"
  }
}
